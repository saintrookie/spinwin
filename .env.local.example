# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - server-only, never expose to the browser.
# Used by all API routes to bypass RLS for reads/writes and to call the draw RPC functions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
